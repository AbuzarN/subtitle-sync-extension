{
    "manifest_version": 3,
    "name": "Subtitle Sync Tool",
    "version": "4.1",
    "description": "Overlay and sync subtitles with adjustable timing",
    "permissions": ["activeTab"],
    "host_permissions": ["<all_urls>"],
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": [
          "state.js",
          "subtitles.js",
          "utils.js",
          "ui.js",
          "content.js"],
        "css": ["style.css"],
        "all_frames": true
      }
    ]
  }